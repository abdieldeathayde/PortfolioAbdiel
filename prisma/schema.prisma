generator client {
  provider = "prisma-client-node"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Projeto {
  id                Int      @id @default(autoincrement())
  titulo            String
  descricao         String
  imagem            String?
  link_github       String?
  tecnologias       String
  ordem             Int      @default(0)
  createdAt         DateTime @default(now())

  @@map("projetos") // Define o nome da tabela no banco
}